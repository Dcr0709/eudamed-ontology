    <!-- http://www.uoc.edu/pac2/eudamed#ActiveDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/pac2/eudamed#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/pac2/eudamed#Device"/>
        <rdfs:comment xml:lang="en">Device needing energy.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/pac2/eudamed#CorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/pac2/eudamed#CorrectiveAction">
        <rdfs:comment xml:lang="en">Field Safety Corrective Action.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/pac2/eudamed#Device -->


    <owl:Class rdf:about="http://www.uoc.edu/pac2/eudamed#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/pac2/eudamed#isManufacturedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/pac2/eudamed#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device or IVD.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/pac2/eudamed#DeviceFailureIncident -->


    <owl:Class rdf:about="http://www.uoc.edu/pac2/eudamed#DeviceFailureIncident">
