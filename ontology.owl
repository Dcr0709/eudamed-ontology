    <owl:Ontology rdf:about="http://www.uoc.edu/pac2/eudamed">
        <rdfs:comment xml:lang="en">Ontology modelling EU Medical Devices, Incidents, Risks and Corrective Actions.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED Medical Devices Ontology</rdfs:label>
