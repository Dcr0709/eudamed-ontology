        <rdfs:comment xml:lang="en">Event caused by malfunction.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Failure Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/pac2/eudamed#EuropeanCountry -->


