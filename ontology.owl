    <!-- http://www.uoc.edu/pac2/eudamed#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#addressesIncident">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Incident"/>
        <rdfs:comment xml:lang="en">Relates FSCA to an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#hasRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the specific risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#involvesDevice">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the affected device.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#isManufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#isManufacturedBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a device to its maker.</rdfs:comment>
        <rdfs:label xml:lang="en">is manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#locatedIn -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#locatedIn">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Location"/>
        <rdfs:comment xml:lang="en">Geographical location of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#mitigatesRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#mitigatesRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/pac2/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/pac2/eudamed#Risk"/>
        <rdfs:comment xml:lang="en">Inferred property of what risk is mitigated.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigates risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/pac2/eudamed#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/pac2/eudamed#reportedBy">
